# ─────────────────────────────────────────────────────────────
# X Intelligence Engine — example environment
# Copy to `.dev.vars` (Workers local) / configure as Worker secrets in prod.
# NEVER put real secrets in this file. NEVER expose these to the browser.
# ─────────────────────────────────────────────────────────────

# Environment
APP_ENV=development
APP_VERSION=local
WEB_ORIGIN=http://localhost:5173
APP_TIMEZONE=Asia/Kolkata

# Authentication
# development mode bypasses auth and is refused when APP_ENV=production
AUTH_MODE=development
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
ALLOWED_EMAILS=

# X API
X_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com
X_WEBHOOK_SECRET=
X_POST_READ_UNIT_COST_USD=0.0
X_USER_READ_UNIT_COST_USD=0.0

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
CLAUDE_INPUT_COST_PER_MILLION=3.0
CLAUDE_OUTPUT_COST_PER_MILLION=15.0

# MCP
MCP_API_TOKEN=
MCP_ALLOW_MUTATIONS=false

# Alerts
ALERT_WEBHOOK_URL=

# Budgets
X_DAILY_RESOURCE_BUDGET=5000
X_MONTHLY_RESOURCE_BUDGET=100000
CLAUDE_DAILY_REQUEST_BUDGET=500
HARD_STOP_ON_BUDGET_EXCEEDED=true

# Feature flags
ENABLE_RAW_ARCHIVE=false
ENABLE_VECTOR_SEARCH=false
DEMO_MODE=false

# Development
LOG_LEVEL=info
